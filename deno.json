{
  "tasks": {
    "dev": "deno run --watch --allow-all mod.ts",
    "test": "deno test --allow-all --no-check test/**/*.test.ts",
    "test:coverage": "deno test --coverage=.coverage --allow-all --no-check test/**/*.test.ts",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "lint:fix": "deno lint --fix",
    "validate": "deno fmt --check && deno lint && deno test --allow-all --no-check test/**/*.test.ts"
  },
  "imports": {
    "cortex/plugins": "https://deno.land/x/cortex@latest/plugins/mod.ts",
    "@std/": "https://deno.land/std@0.208.0/"
  },
  "fmt": {
    "semiColons": true,
    "singleQuote": true,
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ],
      "exclude": [
        "require-await"
      ]
    }
  }
}
